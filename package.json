{
  "name": "contrary-whiteboard",
  "version": "1.0.0",
  "description": "A full-featured digital whiteboard application inspired by OpenBoard",
  "main": "main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "webpack serve --mode development",
